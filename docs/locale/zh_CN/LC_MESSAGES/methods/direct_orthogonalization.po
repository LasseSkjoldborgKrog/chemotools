msgid "Parameters"
msgstr ""

#: chemotools.projection._direct_orthogonalization.DirectOrthogonalization:13
#: chemotools.projection._direct_orthogonalization.DirectOrthogonalization:74
#: of
msgid ""
"The number of orthogonal components to compute. This determines how many "
"orthogonal variations will be removed from the data."
msgstr ""

#: chemotools.projection._direct_orthogonalization.DirectOrthogonalization:16
#: chemotools.projection._direct_orthogonalization.DirectOrthogonalization:77
#: of
msgid ""
"If True, a copy of the input data is created and used for computations. "
"If False, the input data is modified in place."
msgstr ""

