#: ../../source/methods/direct_orthogonalization.rst:2
msgid "Direct Orthogonalization"
msgstr ""

#: chemotools.projection._direct_orthogonalization.DirectOrthogonalization:1 of
msgid ""
"Bases: :py:class:`~sklearn.base.TransformerMixin`, "
":py:class:`~sklearn.base.BaseEstimator`"
msgstr ""

#: chemotools.projection._direct_orthogonalization.DirectOrthogonalization:1 of
msgid ""
"Remove variation in X that is uncorrelated with the target y using Direct"
" Orthogonalization (DO) [1]_ [2]_."
msgstr ""

#: chemotools.projection._direct_orthogonalization.DirectOrthogonalization:4 of
msgid ""
"DO removes from X systematic variation that is independent of y. X is "
"orthogonalized with respect to y, PCA is performed on the orthogonalized "
"matrix to estimate orthogonal components, and those components are "
"subtracted from X to obtain the corrected data."
msgstr ""

#: chemotools.projection._direct_orthogonalization.DirectOrthogonalization:9 of
msgid ""
"The transformer returns the corrected matrix with the same number of "
"features, retaining variation relevant for predicting y. Inputs are "
"typically assumed to be mean-centered."
msgstr ""

